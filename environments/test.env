# 测试环境配置
ENVIRONMENT=test
OPENAI_API_KEY=sk-test-key-for-testing
DATABASE_URL=sqlite:///./test.db
REDIS_URL=redis://localhost:6379/1

# 前端测试环境
NEXT_PUBLIC_API_BASE_URL=http://localhost:8002/api/v1
NEXT_PUBLIC_SSE_BASE_URL=http://localhost:8002
NEXT_PUBLIC_ENABLE_MOCK_MODE=true

# 测试配置
TEST_BACKEND_URL=http://localhost:8001
TEST_FRONTEND_URL=http://localhost:3000
TEST_API_TIMEOUT=30
TEST_PAGE_TIMEOUT=10
HEADLESS_BROWSER=true
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=false

# 性能测试
LOAD_TEST_USERS=10
LOAD_TEST_DURATION=60
